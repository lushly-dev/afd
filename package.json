{
	"name": "afd",
	"version": "0.6.0",
	"private": true,
	"description": "Agent-First Development - Build software where AI agents are first-class users",
	"repository": {
		"type": "git",
		"url": "https://github.com/lushly-dev/afd.git"
	},
	"author": "Falkicon",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=9.0.0"
	},
	"packageManager": "pnpm@10.30.1",
	"scripts": {
		"build": "pnpm -r build",
		"clean": "pnpm -r clean && rimraf node_modules",
		"dev": "pnpm -r --parallel dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "pnpm -r test",
		"test:coverage": "pnpm -r --no-bail test -- --coverage",
		"test:watch": "pnpm -r --parallel test:watch",
		"typecheck": "pnpm -r typecheck",
		"check": "npx lefthook run check",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"publish:npm": "pnpm build && changeset publish",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"lefthook": "^2.1.4",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
