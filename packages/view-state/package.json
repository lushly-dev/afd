{
	"name": "@lushly-dev/afd-view-state",
	"version": "0.6.0",
	"description": "UI view state management via AFD commands — panels, sidebars, selections, tool modes",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"clean": "rimraf dist *.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"afd",
		"agent-first",
		"view-state",
		"ui-state",
		"mcp"
	],
	"author": "Falkicon",
	"license": "MIT",
	"homepage": "https://github.com/lushly-dev/afd#readme",
	"bugs": {
		"url": "https://github.com/lushly-dev/afd/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lushly-dev/afd.git",
		"directory": "packages/view-state"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"sideEffects": false,
	"dependencies": {
		"@lushly-dev/afd-server": "workspace:*",
		"zod": "^4.0.0"
	},
	"peerDependencies": {
		"@lushly-dev/local-db": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@lushly-dev/local-db": {
			"optional": true
		}
	},
	"devDependencies": {
		"@lushly-dev/afd-testing": "workspace:*",
		"@lushly-dev/local-db": "workspace:*",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
