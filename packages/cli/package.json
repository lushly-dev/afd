{
	"name": "@lushly-dev/afd-cli",
	"version": "0.6.0",
	"description": "Command-line interface for Agent-First Development",
	"type": "module",
	"bin": {
		"afd": "./dist/bin.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"clean": "rimraf dist *.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"start": "node dist/bin.js"
	},
	"keywords": [
		"afd",
		"cli",
		"mcp",
		"ai-agents",
		"command-line"
	],
	"author": "Falkicon",
	"license": "MIT",
	"homepage": "https://github.com/lushly-dev/afd#readme",
	"bugs": {
		"url": "https://github.com/lushly-dev/afd/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lushly-dev/afd.git",
		"directory": "packages/cli"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@lushly-dev/afd-client": "workspace:*",
		"@lushly-dev/afd-core": "workspace:*",
		"@lushly-dev/afd-testing": "workspace:*",
		"chalk": "^5.6.2",
		"commander": "^14.0.0",
		"conf": "^15.0.0",
		"glob": "^13.0.0",
		"ora": "^9.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
