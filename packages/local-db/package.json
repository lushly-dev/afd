{
	"name": "@lushly-dev/local-db",
	"version": "0.4.0",
	"description": "Async data adapter with swappable backends (Memory, HTTP, Browser) for Agent-First Development",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"clean": "rimraf dist *.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"afd",
		"agent-first",
		"database",
		"adapter",
		"sqlite",
		"local-storage",
		"data-layer"
	],
	"author": "Falkicon",
	"license": "MIT",
	"homepage": "https://github.com/lushly-dev/afd#readme",
	"bugs": {
		"url": "https://github.com/lushly-dev/afd/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lushly-dev/afd.git",
		"directory": "packages/local-db"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": false,
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@vitest/coverage-v8": "^4.0.18",
		"rimraf": "^6.0.1",
		"typescript": "^5.7.2",
		"vitest": "^4.0.18"
	},
	"publishConfig": {
		"access": "public"
	}
}
