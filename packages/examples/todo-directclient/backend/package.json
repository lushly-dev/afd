{
	"name": "@afd/example-todo-directclient",
	"private": true,
	"version": "0.1.0",
	"description": "Example: Todo app with DirectClient + AI Copilot integration",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./server": {
			"import": "./dist/server.js",
			"types": "./dist/server.d.ts"
		},
		"./registry": {
			"import": "./dist/registry.js",
			"types": "./dist/registry.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/server.js",
		"dev": "tsx watch src/server.ts",
		"chat": "tsx src/chat-server.ts",
		"benchmark": "tsx src/benchmark/compare.ts",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@google/genai": "^1.45.0",
		"@lushly-dev/afd-client": "workspace:*",
		"@lushly-dev/afd-core": "workspace:*",
		"@lushly-dev/afd-server": "workspace:*",
		"dotenv": "^17.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
